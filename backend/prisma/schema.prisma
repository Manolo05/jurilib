// Jurilib — Prisma schema (équivalent du SQL)
// docker run postgres + npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  lawyer
  admin
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum MeetingType {
  video
  in_person
  phone
}

enum VerificationStatus {
  unverified
  pending
  verified
  rejected
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  role          UserRole  @default(client)
  emailVerified Boolean   @default(false) @map("email_verified")
  avatarUrl     String?   @map("avatar_url")
  locale        String    @default("fr-FR")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  lawyer        Lawyer?
  appointments  Appointment[]    @relation("ClientAppointments")
  reviews       Review[]
  notifications Notification[]
  sentMessages  Message[]
  threads       MessageThread[]

  @@map("users")
}

model Lawyer {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                 String             @unique
  barAssociation       String             @map("bar_association")
  barNumber            String?            @map("bar_number")
  yearsExperience      Int                @default(0) @map("years_experience")
  bio                  String?
  consultationPrice    Decimal            @map("consultation_price") @db.Decimal(8, 2)
  consultationDuration Int                @default(30) @map("consultation_duration")
  currency             String             @default("EUR")
  ratingAvg            Decimal            @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount          Int                @default(0) @map("rating_count")
  verified             VerificationStatus @default(unverified)
  acceptsVideo         Boolean            @default(true) @map("accepts_video")
  acceptsInPerson      Boolean            @default(true) @map("accepts_in_person")
  addressLine          String?            @map("address_line")
  city                 String
  postalCode           String?            @map("postal_code")
  country              String             @default("FR")
  latitude             Decimal?           @db.Decimal(9, 6)
  longitude            Decimal?           @db.Decimal(9, 6)
  stripeAccountId      String?            @map("stripe_account_id")
  isActive             Boolean            @default(true) @map("is_active")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  specialties    LawyerSpecialty[]
  availabilities Availability[]
  appointments   Appointment[]
  reviews        Review[]

  @@index([city])
  @@index([verified])
  @@index([ratingAvg])
  @@map("lawyers")
}

model Specialty {
  id       Int               @id @default(autoincrement())
  slug     String            @unique
  label    String
  lawyers  LawyerSpecialty[]

  @@map("specialties")
}

model LawyerSpecialty {
  lawyerId    String    @map("lawyer_id")
  specialtyId Int       @map("specialty_id")
  lawyer      Lawyer    @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([lawyerId, specialtyId])
  @@map("lawyer_specialties")
}

model Availability {
  id           String      @id @default(uuid())
  lawyerId     String      @map("lawyer_id")
  lawyer       Lawyer      @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  startsAt     DateTime    @map("starts_at")
  endsAt       DateTime    @map("ends_at")
  isBooked     Boolean     @default(false) @map("is_booked")
  meetingType  MeetingType @default(video) @map("meeting_type")
  createdAt    DateTime    @default(now()) @map("created_at")

  appointment  Appointment?

  @@index([lawyerId, startsAt])
  @@map("availabilities")
}

model Appointment {
  id                String            @id @default(uuid())
  clientId          String            @map("client_id")
  client            User              @relation("ClientAppointments", fields: [clientId], references: [id])
  lawyerId          String            @map("lawyer_id")
  lawyer            Lawyer            @relation(fields: [lawyerId], references: [id])
  availabilityId    String?           @unique @map("availability_id")
  availability      Availability?     @relation(fields: [availabilityId], references: [id])
  startsAt          DateTime          @map("starts_at")
  endsAt            DateTime          @map("ends_at")
  status            AppointmentStatus @default(pending)
  meetingType       MeetingType       @default(video) @map("meeting_type")
  meetingUrl        String?           @map("meeting_url")
  notes             String?
  cancellationReason String?          @map("cancellation_reason")
  priceCharged      Decimal           @map("price_charged") @db.Decimal(8, 2)
  currency          String            @default("EUR")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  payment Payment?
  review  Review?

  @@index([clientId, startsAt])
  @@index([lawyerId, startsAt])
  @@map("appointments")
}

model Payment {
  id                    String        @id @default(uuid())
  appointmentId         String        @unique @map("appointment_id")
  appointment           Appointment   @relation(fields: [appointmentId], references: [id])
  amount                Decimal       @db.Decimal(8, 2)
  currency              String        @default("EUR")
  status                PaymentStatus @default(pending)
  stripePaymentIntent   String?       @unique @map("stripe_payment_intent")
  stripeChargeId        String?       @map("stripe_charge_id")
  platformFee           Decimal?      @default(0) @map("platform_fee") @db.Decimal(8, 2)
  paymentMethod         String?       @map("payment_method")
  refundedAmount        Decimal?      @default(0) @map("refunded_amount") @db.Decimal(8, 2)
  receiptUrl            String?       @map("receipt_url")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model Review {
  id            String       @id @default(uuid())
  clientId      String       @map("client_id")
  client        User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lawyerId      String       @map("lawyer_id")
  lawyer        Lawyer       @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique @map("appointment_id")
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  isPublished   Boolean      @default(true) @map("is_published")
  lawyerReply   String?      @map("lawyer_reply")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("reviews")
}

model MessageThread {
  id        String    @id @default(uuid())
  clientId  String    @map("client_id")
  lawyerId  String    @map("lawyer_id")
  client    User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")

  messages  Message[]

  @@unique([clientId, lawyerId])
  @@map("message_threads")
}

model Message {
  id        String        @id @default(uuid())
  threadId  String        @map("thread_id")
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String        @map("sender_id")
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  readAt    DateTime?     @map("read_at")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@map("messages")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("notifications")
}
